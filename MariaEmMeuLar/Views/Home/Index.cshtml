                <i class="fa-solid fa-calendar-days"></i>
                <span>Programação</span>
            </a>

            <a href="#horario" class="mobile-menu-link">
                <i class="fa-regular fa-clock"></i>
                <span>Horário</span>
            </a>

            <a href="#galeria" class="mobile-menu-link">
                <i class="fa-solid fa-camera"></i>
                <span>Galeria</span>
            </a>

            <a href="#inscricao" class="mobile-menu-link">
                <i class="fa-solid fa-download"></i>
                <span>Inscrição</span>
            </a>

            <a href="#contato" class="mobile-menu-link">
                <i class="fa-solid fa-phone"></i>
                <span>Contato</span>
            </a>

            <a href="#local" class="mobile-menu-link">
                <i class="fa-solid fa-location-dot"></i>
                <span>Como chegar</span>
            </a>
        </nav>
