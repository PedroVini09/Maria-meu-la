@{
    ViewData["Title"] = "Maria em Meu Lar";
}
<header class="hero" id="inicio">
    <nav class="navbar">
        <div class="logo-area">
            <img src="~/img/logo_paroquia.png" alt="Logo Paróquia Sagrado Coração de Jesus" class="logo-img"/>

            <div class="logo-text">
                <strong>Sagrado Coração</strong>
                <span>de Jesus</span>
            </div>
        </div>

        <ul class="menu">
            <li>
                <a href="#inicio" class="menu-link">
                    <i class="fa-solid fa-house"></i>
                    <span>Início</span>
                </a>
            </li>

            <li>
                <a href="#programacao" class="menu-link">
                    <i class="fa-solid fa-calendar-days"></i>
                    <span>Programação</span>
                </a>
            </li>

            <li>
                <a href="#galeria" class="menu-link">
                    <i class="fa-solid fa-camera"></i>
                    <span>Galeria</span>
                </a>
            </li>

            <li>
                <a href="#inscricao" class="menu-link">
                    <i class="fa-solid fa-download"></i>
                    <span>Inscrição</span>
                </a>
            </li>

            <li>
                <a href="#contato" class="menu-link">
                    <i class="fa-solid fa-phone"></i>
                    <span>Contato</span>
                </a>
            </li>
        </ul>

        <a href="#local" class="btn_route">
            <i class="fa-solid fa-location-dot"></i>
            <span>Como chegar</span>
        </a>

        <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Abrir menu">
            <i class="fa-solid fa-bars"></i>
        </button>
    </nav>

    <div class="mobile-overlay" id="mobileOverlay"></div>

    <aside class="mobile-drawer" id="mobileDrawer">
        <div class="mobile-drawer-header">
            <img src="~/img/logo_paroquia.png" alt="Logo Paróquia"/>
            <div>
                <strong>Sagrado Coração</strong>
                <span>de Jesus</span>
            </div>
        </div>

        <nav class="mobile-drawer-nav">
            <a href="#inicio" class="mobile-menu-link">
                <i class="fa-solid fa-house"></i>
                <span>Início</span>
            </a>

            <a href="#programacao" class="mobile-menu-link">
                <i class="fa-solid fa-calendar-days"></i>
                <span>Programação</span>
            </a>

            <a href="#horario" class="mobile-menu-link">
                <i class="fa-regular fa-clock"></i>
                <span>Horário</span>
            </a>

            <a href="#galeria" class="mobile-menu-link">
                <i class="fa-solid fa-camera"></i>
                <span>Galeria</span>
            </a>

            <a href="#inscricao" class="mobile-menu-link">
                <i class="fa-solid fa-download"></i>
                <span>Inscrição</span>
            </a>

            <a href="#contato" class="mobile-menu-link">
                <i class="fa-solid fa-phone"></i>
                <span>Contato</span>
            </a>

            <a href="#local" class="mobile-menu-link">
                <i class="fa-solid fa-location-dot"></i>
                <span>Como chegar</span>
            </a>
        </nav>
        <div class="mobile-drawer-footer">
            <img src="~/img/maria_dourado.png" alt="" class="drawer-maria" aria-hidden="true"/>

            <p>
                "Com Maria,<br/>
                Jesus entra em nosso lar."
            </p>
        </div>
    </aside>
    
    <section class="hero-content">
        <div class="hero-text">
            <h1>
                <span>Maria em</span>
                <span>Meu Lar</span>
            </h1>


            <div class="welcome-divider">
                <span></span>
                <i class="fa-solid fa-diamond"></i>
                <span></span>
            </div>

            <blockquote class="hero-quote">
                <p>“Nunca tenha medo de amar demais a Virgem Maria.”</p>
                <cite>— São Maximiliano Kolbe</cite>
            </blockquote>

            <a href="#local" class="hero-mobile-route">
                <i class="fa-solid fa-location-dot"></i>
                <span>Como chegar</span>
            </a>
        </div>
        
        <div class="hero-image">
            <img src="~/img/maria-ilustracao.png" alt="Maria segurando uma criança" class="maria-img"/>
        </div>
       
    </section>
</header>

<section class="welcome-section welcome-animate" id="sobre">
    <div class="welcome-container">

        <div class="welcome-heading">
            <h2>Bem-vindo ao<br/>Maria em Meu Lar</h2>

            <div class="welcome-divider">
                <span></span>
                <i class="fa-solid fa-diamond"></i>
                <span></span>
            </div>

            <p>
                Um caminho de fé que transforma casas em verdadeiros lares.<br/>
                Convidamos sua família a viver a presença de Maria todos os dias.
            </p>
        </div>

        <div class="welcome-content-grid">

            <div class="welcome-photo-area">
                <div class="welcome-photo-card">
                    <img src="~/img/imagem de maria e o povo no fundo.png" alt="Família reunida em oração com Maria"/>
                </div>
            </div>

            <div class="welcome-info-area">

                <div class="welcome-feature-row">
                    <div class="welcome-feature">
                        <i class="fa-solid fa-hands-praying"></i>

                        <div>
                            <h3>Levar Maria ao<br/>coração do lar</h3>
                            <p>
                                Promovemos encontros e momentos de oração que fortalecem a fé
                                e aproximam as famílias de Jesus por meio de Maria.
                            </p>
                        </div>
                    </div>

                    <div class="welcome-feature">
                        <i class="fa-solid fa-people-roof"></i>

                        <div>
                            <h3>Construir lares<br/>que oram juntos</h3>
                            <p>
                                Acreditamos que a oração em família gera paz, esperança e unidade,
                                renovando o amor de Deus em cada dia.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="welcome-card-row">
                    <div class="welcome-card">
                        <i class="fa-solid fa-heart-circle-plus"></i>

                        <div>
                            <h3>Presença Mariana</h3>
                            <p>
                                Maria caminha conosco, intercede, protege e conduz cada família
                                à luz do seu Filho.
                            </p>
                        </div>
                    </div>

                    <div class="welcome-card">
                        <i class="fa-solid fa-people-group"></i>

                        <div>
                            <h3>União da Família</h3>
                            <p>
                                Quando a família reza unida, o lar se torna um santuário de fé,
                                amor e perdão.
                            </p>
                        </div>
                    </div>
                </div>

                <a href="#programacao" class="welcome-button">
                    <span>Descubra Mais</span>
                    <i class="fa-solid fa-chevron-right"></i>
                </a>

            </div>
        </div>

        <div class="welcome-m-symbol">M</div>

    </div>
</section>