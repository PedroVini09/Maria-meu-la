@{
    ViewData["Title"] = "Maria em Meu Lar";
}
<header class="hero" id="inicio">
    <nav class="navbar">
        <div class="logo-area">
            <img src="~/img/logo_paroquia.png" alt="Logo Paróquia Sagrado Coração de Jesus" class="logo-img"/>

            <div class="logo-text">
                <strong>Sagrado Coração</strong>
                <span>de Jesus</span>
            </div>
        </div>

        <ul class="menu">
            <li>
                <a href="#inicio" class="menu-link">
                    <i class="fa-solid fa-house"></i>
                    <span>Início</span>
                </a>
            </li>

            <li>
                <a href="#programacao" class="menu-link">
                    <i class="fa-solid fa-calendar-days"></i>
                    <span>Programação</span>
                </a>
            </li>

            <li>
                <a href="#galeria" class="menu-link">
                    <i class="fa-solid fa-camera"></i>
                    <span>Galeria</span>
                </a>
            </li>

            <li>
                <a href="#inscricao" class="menu-link">
                    <i class="fa-solid fa-download"></i>
                    <span>Inscrição</span>
                </a>
            </li>

            <li>
                <a href="#contato" class="menu-link">
                    <i class="fa-solid fa-phone"></i>
                    <span>Contato</span>
                </a>
            </li>
        </ul>

        <a href="#local" class="btn_route">
            <i class="fa-solid fa-location-dot"></i>
            <span>Como chegar</span>
        </a>

        <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Abrir menu">
            <i class="fa-solid fa-bars"></i>
        </button>
    </nav>

    <div class="mobile-overlay" id="mobileOverlay"></div>

    <aside class="mobile-drawer" id="mobileDrawer">
        <div class="mobile-drawer-header">
            <img src="~/img/logo_paroquia.png" alt="Logo Paróquia"/>
            <div>
                <strong>Sagrado Coração</strong>
                <span>de Jesus</span>
            </div>
        </div>

        <nav class="mobile-drawer-nav">
            <a href="#inicio" class="mobile-menu-link">
                <i class="fa-solid fa-house"></i>
                <span>Início</span>
            </a>

            <a href="#programacao" class="mobile-menu-link">
                <i class="fa-solid fa-calendar-days"></i>
                <span>Programação</span>
            </a>

            <a href="#horario" class="mobile-menu-link">
                <i class="fa-regular fa-clock"></i>
                <span>Horário</span>
            </a>

            <a href="#galeria" class="mobile-menu-link">
                <i class="fa-solid fa-camera"></i>
                <span>Galeria</span>
            </a>

            <a href="#inscricao" class="mobile-menu-link">
                <i class="fa-solid fa-download"></i>
                <span>Inscrição</span>
            </a>

            <a href="#contato" class="mobile-menu-link">
                <i class="fa-solid fa-phone"></i>
                <span>Contato</span>
            </a>

            <a href="#local" class="mobile-menu-link">
                <i class="fa-solid fa-location-dot"></i>
                <span>Como chegar</span>
            </a>
        </nav>
        <div class="mobile-drawer-footer">
            <img src="~/img/maria_dourado.png" alt="" class="drawer-maria" aria-hidden="true"/>

            <p>
                "Com Maria,<br/>
                Jesus entra em nosso lar."
            </p>
        </div>
    </aside>
    
    <section class="hero-content">
        <div class="hero-text">
            <h1>
                <span>Maria em</span>
                <span>Meu Lar</span>
            </h1>

            <blockquote class="hero-quote">
                <p>“Nunca tenha medo de amar demais a Virgem Maria.”</p>
                <cite>— São Maximiliano Kolbe</cite>
            </blockquote>

            <a href="#local" class="hero-mobile-route">
                <i class="fa-solid fa-location-dot"></i>
                <span>Como chegar</span>
            </a>
        </div>
        
        <div class="hero-image">
            <img src="~/img/maria-ilustracao.png" alt="Maria segurando uma criança" class="maria-img"/>
        </div>
       
    </section>
</header>

<section class="welcome-section" id="sobre">
    <div class="welcome-container">
        
        <div class="welcome-image-area">
            <div class="welcome-imagem-card">
                <img src="~/img/R118-EVA-Imaculado-Coracao-de-Maria.jpg" alt="Maria em meu lar"/>
            </div>
            
            <div class="welcome-badge">
                <i class="fa-solid fa-heart"></i>
                <span>Fé • Família • Oração</span>
            </div>
        </div>
        
        <div class="welcome-content">
            <span class="section-label">Sobre o projeto</span>
            
            <h2>Bem-vindo ao<br/>Maria em Meu Lar</h2>
            
            <div class="section-divider">
                <span></span>
                <i class="fa-solid fa-diamond"></i>
                <span></span>
            </div>
            
            <p>
                O Maria em Meu Lar é um projeto de fé e acolhimento que leva a presença
                de Nossa Senhora às famílias, fortalecendo a oração, a união e a vida em comunidade.
            </p>
            
            <p>
                Em cada visita, queremos abrir as portas do coração para Jesus, por meio de Maria,
                criando momentos de partilha, espiritualidade e esperança dentro do lar.
            </p>
            
            <div class="welcome-cards">
                <div class="welcome-card">
                    <i class="fa-solid fa-heart-cicle-plus"></i>
                    <div>
                        <h3>Nossa Missão</h3>
                        <p>Levar oração, paz e presença mariana as famílias.</p>
                    </div>
                </div>
                
                <div class="welcome-card">
                    <i class="fa-solid fa-hands-holding-heart"></i>
                    
                    <div>
                        <h3>Acolhimento</h3>
                        <p>Um encontro simples, fraterno e cheio de fé.</p>
                    </div>
                </div>
            </div>
            
            <a href="#programação" class="welcome-button">
                <span>Conheça o Projeto</span>
                <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
        
    </div>
</section>